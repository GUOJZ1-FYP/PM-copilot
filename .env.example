# ==============================================================================
# Environment Variables — PM-Copilot
# ==============================================================================
# Copy this file to `.env` and fill in only the values needed for the workflow
# you are running. Do not commit real API keys or credentials.
#
# The public repository currently contains demo/documentation material only. These
# variables document the expected configuration shape for the future code release.
# ==============================================================================


# ------------------------------------------------------------------------------
# AI providers — needed for LLM synthesis, commentary regeneration, and digest runs
# ------------------------------------------------------------------------------
# Primary: Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Fallback / research provider
OPENROUTER_API_KEY=


# ------------------------------------------------------------------------------
# Data-source APIs — needed for running the data-fetch pipeline
# ------------------------------------------------------------------------------
# Reddit (PRAW)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=script:pm_copilot:v1.0

# X / Twitter via twitterapi.io
TWITTERAPI_IO_API_KEY=

# News search and scraping
BRAVE_API_KEY=
FIRECRAWL_API_KEY=

# IPO calendar / company reference data
FINNHUB_API_KEY=


# ------------------------------------------------------------------------------
# Yahoo Finance / VPN guard
# ------------------------------------------------------------------------------
# local = direct yfinance, server = enforce host-level VPN guard before fetches
YF_RUNTIME_ENV=local
REQUIRE_YF_VPN=
YF_VPN_COUNTRY=Singapore


# ------------------------------------------------------------------------------
# Optional email digest delivery
# ------------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_DIGEST_TO=


# ------------------------------------------------------------------------------
# Optional LLM-as-judge evaluation tuning
# ------------------------------------------------------------------------------
JUDGE_MODEL=deepseek/deepseek-chat
JUDGE_MAX_WORKERS=5
JUDGE_SCORE_THRESHOLD=0.6


# ------------------------------------------------------------------------------
# Claude Code CLI
# ------------------------------------------------------------------------------
# Some pipeline steps may shell out to the `claude` CLI. Install and authenticate
# it on the host machine separately. No Claude API key belongs in this file.
